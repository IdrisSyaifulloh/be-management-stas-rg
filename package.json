{
  "name": "be-managementstas",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "start": "node ./bin/www",
    "dev": "nodemon ./bin/www",
    "check:config": "node ./scripts/checkConfig.js",
    "db:migrate": "node ./db/runSqlFile.js ./db/schema.sql",
    "db:seed": "node ./db/runSqlFile.js ./db/seed.sql",
    "db:clear": "node ./db/runSqlFile.js ./db/clear.sql",
    "db:create-operator": "node ./db/runSqlFile.js ./db/create_operator.sql",
    "db:reset": "npm run db:migrate && npm run db:seed",
    "db:migrate-withdrawal": "node ./db/runSqlFile.js ./db/migrations/001_add_withdrawal_tracking.sql"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cookie-parser": "~1.4.4",
    "cors": "^2.8.5",
    "debug": "~2.6.9",
    "dotenv": "^16.5.0",
    "express": "~4.16.1",
    "express-validator": "^7.3.1",
    "http-errors": "~1.6.3",
    "jade": "~1.11.0",
    "morgan": "~1.9.1",
    "pg": "^8.16.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "nodemon": "^3.1.10"
  }
}
