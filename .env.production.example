NODE_ENV=production
PORT=3000

# FE domain yang diizinkan akses API (pisahkan pakai koma jika lebih dari satu)
CORS_ORIGIN=https://app.stasrg.ac.id

# JWT Secret untuk signing tokens (gunakan string random yang kuat, min 32 karakter)
JWT_SECRET=your-super-secret-key-here-change-in-production

# Gunakan salah satu opsi koneksi database:
# Opsi 1 (direkomendasikan): connection string tunggal
DATABASE_URL=postgres://db_user:db_password@db_host:5432/stasrg

# Opsi 2 (jika tidak memakai DATABASE_URL)
# DB_HOST=db_host
# DB_PORT=5432
# DB_NAME=stasrg
# DB_USER=db_user
# DB_PASSWORD=db_password
